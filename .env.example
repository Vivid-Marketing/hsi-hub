APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Postmark (transactional email — Courses Parser, job notifications, etc.)
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=noreply@hsi.com
# Production: set MAIL_MAILER=postmark and MAIL_FROM_ADDRESS to a verified sender signature.
# Example:
# MAIL_MAILER=postmark
# MAIL_FROM_ADDRESS=noreply@hsi.com
# POSTMARK_MESSAGE_STREAM=outbound
# POSTMARK_COURSE_CATALOG_LOGO_URL=
# POSTMARK_CONTACT_URL=https://hsi.com/contact
# POSTMARK_HSI_HOME_URL=https://hsi.com

# Cron (Cloudways) - protects cron entrypoint file
CRON_TOKEN=

# Scheduler "one cron hit" token (for /internal/cron/schedule?token=...)
CRON_SCHEDULE_TOKEN=

# Course Catalog PDF (internal signed endpoint + PDF upload)
COURSE_LIBRARY_PDF_SHARED_SECRET=
# Comma-separated list of allowed browser origins (optional)
COURSE_CATALOG_PDF_ALLOWED_ORIGINS=https://stage.hsi.com,https://hsi.com
# Optional: override DO Spaces creds for PDFs (defaults to CLD_DO_SPACES_*)
# COURSE_CATALOG_PDF_DO_SPACES_KEY=
# COURSE_CATALOG_PDF_DO_SPACES_SECRET=
# COURSE_CATALOG_PDF_DO_SPACES_BUCKET=hsiassetstorage
# COURSE_CATALOG_PDF_DO_SPACES_REGION=sfo2
# COURSE_CATALOG_PDF_DO_SPACES_ENDPOINT=https://sfo2.digitaloceanspaces.com
# COURSE_CATALOG_PDF_DO_SPACES_BASE_PATH=reports/courses/pdf
# COURSE_CATALOG_PDF_LOCAL_DEBUG=true

# Training Assessment PDF (legacy generateReportHtml*.php; public endpoints for now)
# Comma-separated list of allowed browser origins (optional). Defaults to COURSE_CATALOG_PDF_ALLOWED_ORIGINS if unset.
TRAINING_ASSESSMENT_PDF_ALLOWED_ORIGINS=
# Optional: override DO Spaces creds for PDFs (defaults to CLD_DO_SPACES_*)
# TRAINING_ASSESSMENT_PDF_DO_SPACES_KEY=
# TRAINING_ASSESSMENT_PDF_DO_SPACES_SECRET=
# TRAINING_ASSESSMENT_PDF_DO_SPACES_BUCKET=hsiassetstorage
# TRAINING_ASSESSMENT_PDF_DO_SPACES_REGION=sfo2
# TRAINING_ASSESSMENT_PDF_DO_SPACES_ENDPOINT=https://sfo2.digitaloceanspaces.com
# TRAINING_ASSESSMENT_PDF_DO_SPACES_BASE_PATH=reports/training-assessments/pdf
# TRAINING_ASSESSMENT_PDF_LOCAL_DEBUG=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# CLD API (Courses API sync)
CLD_API_BASE_URL=https://cldapi.hsiplatform.com
CLD_API_ADMIN_ID=
CLD_API_PASSWORD=
CLD_FEEDS_PASSKEY=
CLD_UI_MAX_SINGLES_IDS=50
CLD_FEEDME_PASSKEY=
CLD_FEEDME_PROD_FEED_ID=70
# FeedMe HTTP read timeout in seconds (imports can take several minutes)
CLD_FEEDME_TIMEOUT=300
# Email (Postmark) for CLD sync failure summaries; leave empty to log only
CLD_SYNC_NOTIFY_EMAIL=
# Set true to email even when sync fully succeeds
CLD_SYNC_NOTIFY_ON_SUCCESS=false
# DigitalOcean Spaces (course images CDN)
CLD_DO_SPACES_KEY=
CLD_DO_SPACES_SECRET=
CLD_DO_SPACES_BUCKET=hsiassetstorage
CLD_DO_SPACES_REGION=sfo2
CLD_DO_SPACES_ENDPOINT=https://sfo2.digitaloceanspaces.com
